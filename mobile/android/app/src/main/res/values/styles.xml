<resources>

    <!-- Shown instantly on cold start — logo on navy before JS loads. -->
    <style name="SplashTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@color/brand_navy</item>
        <item name="android:navigationBarColor">@color/brand_navy</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Main app theme after React Native takes over. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <!-- Keep logo visible until React Native draws its first opaque frame. -->
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@color/brand_navy</item>
    </style>

</resources>
